# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nexus_ai_db

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=7d

# Web3 & Blockchain
NEXT_PUBLIC_ALCHEMY_ID=your_alchemy_api_key
NEXT_PUBLIC_INFURA_ID=your_infura_api_key
NEXT_PUBLIC_WAGMI_PROJECT_ID=your_walletconnect_project_id

# Smart Contracts
NEXT_PUBLIC_AI_MODEL_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_PAYMENT_MANAGER_ADDRESS=0x...
NEXT_PUBLIC_REPUTATION_SYSTEM_ADDRESS=0x...
NEXT_PUBLIC_MARKETPLACE_TOKEN_ADDRESS=0x...

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pinata (IPFS)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
PINATA_JWT=your_pinata_jwt_token

# OpenAI (for AI features)
OPENAI_API_KEY=sk_...

# HuggingFace
HUGGINGFACE_API_KEY=hf_...

# Analytics & Monitoring
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Email Service
SENDGRID_API_KEY=SG_...

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Ethereum RPC (Optional if using custom)
NEXT_PUBLIC_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/...
NEXT_PUBLIC_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/...
NEXT_PUBLIC_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/...
NEXT_PUBLIC_ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/...

# Feature Flags
NEXT_PUBLIC_ENABLE_GOVERNANCE=true
NEXT_PUBLIC_ENABLE_STAKING=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379

# Hardhat Network Config (for local development)
HARDHAT_NETWORK=localhost
HARDHAT_NETWORK_ID=31337
